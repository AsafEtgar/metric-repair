# --- OS / editor cruft ---
.DS_Store
Icon?
.vscode/
__pycache__/
*.pyc

# --- Jupyter ---
.ipynb_checkpoints/

# --- Local scratch notebook (Sage-flavored `%run`; not part of the pure-Python port) ---
sanity_checks.ipynb

# --- Sage preparser cache ---
*.sage.py

# --- Equivalence proof (regenerable by export_reference.sage) ---
equivalence/reference.json

# --- Experiment output (regenerable; the dir itself is kept via .gitkeep) ---
results/*
!results/.gitkeep

# --- Cluster run artifacts (generated by experiments/submit_dsq.sh; regenerable) ---
joblist.txt
small_joblist.txt
large_joblist.txt
dsq_submit.sh
dsq_small_submit.sh
dsq_large_submit.sh
dsq-joblist-*.sh
results_all.csv
results_small_all.csv
results_large_all.csv
results_small/
results_large/
logs/

# --- RGG experiment output + cluster artifacts (generated by submit_rgg_dsq.sh; regenerable) ---
results_rgg/
results_rgg_*/
rgg_joblist.txt
rgg_*_joblist.txt
dsq_rgg_submit.sh
dsq_rgg_*_submit.sh
results_rgg*_all.csv

# --- Real-dataset experiment output + cluster artifacts (regenerable; submit_real_dsq.sh) ---
results_real/
results_real_covers/
real_*_joblist.txt
dsq_real_*_submit.sh
results_real_all.csv

# --- Analysis output (regenerable from results by experiments/analyze.py) ---
analysis/

# --- Real datasets (large/private stays local; structure + examples are tracked) ---
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
# the built graphs (~13MB) ARE tracked so the cluster gets them via git pull (scp was flaky).
# GT artifacts under data/processed/gt/ stay ignored (regenerable locally by ground_truth.py).
!data/processed/*.csv
# (data/examples/ and data/README.md are tracked normally)

# Notes:
# - res_finalle/ and plots_paper/ ARE tracked (paper artifacts consumed by PAPER_PLOTS.ipynb).
# - outputs/ (generated PDFs) is tracked too; ignore it if those get large.
# - Large notebooks (e.g. AVG_HYPERBOLICITY.ipynb) carry embedded output. Consider `nbstripout`
#   to keep diffs small if the repo grows.
